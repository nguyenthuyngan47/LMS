<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="email_template_lecturer_welcome" model="mail.template">
        <field name="name">LMS - Welcome Lecturer (VI)</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="subject">[LMS] Chúc mừng bạn đã được kích hoạt tài khoản giảng viên</field>
        <field name="email_from">{{ (user.email_formatted or user.company_id.email_formatted or '') }}</field>
        <field name="email_to">{{ object.email or object.login }}</field>
        <field name="auto_delete" eval="False"/>
        <field name="body_html" type="html">
            <table border="0" cellpadding="0" cellspacing="0" style="width:100%;background:#f6f8fb;padding:24px 0;font-family:Arial,sans-serif;color:#1f2937;">
                <tr>
                    <td align="center">
                        <table border="0" cellpadding="0" cellspacing="0" style="width:640px;max-width:94%;background:#ffffff;border:1px solid #e5e7eb;border-radius:12px;overflow:hidden;">
                            <tr>
                                <td style="background:#4f46e5;color:#ffffff;padding:18px 24px;font-size:18px;font-weight:700;">
                                    LMS - Thông báo kích hoạt tài khoản giảng viên
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:24px;font-size:14px;line-height:1.7;">
                                    <p style="margin:0 0 12px 0;">Kính chào <strong><t t-out="object.name or object.login"/></strong>,</p>
                                    <p style="margin:0 0 12px 0;">
                                        Tài khoản của bạn đã được phê duyệt và kích hoạt với vai trò
                                        <strong>Giảng viên</strong> trên hệ thống LMS.
                                    </p>
                                    <p style="margin:0 0 18px 0;">
                                        Bạn có thể đăng nhập để bắt đầu quản lý lớp học và nội dung giảng dạy.
                                    </p>
                                    <p style="margin:0 0 22px 0;">
                                        <a t-att-href="(object.get_base_url() or '').rstrip('/') + '/web/login?login=%s' % (object.login or object.email or '')"
                                           style="display:inline-block;background:#4f46e5;color:#ffffff;text-decoration:none;padding:10px 18px;border-radius:8px;font-weight:600;">
                                            Đăng nhập hệ thống
                                        </a>
                                    </p>
                                    <p style="margin:0;color:#6b7280;font-size:13px;">
                                        Nếu nút không hiển thị, vui lòng truy cập:
                                        <a t-att-href="(object.get_base_url() or '').rstrip('/') + '/web/login?login=%s' % (object.login or object.email or '')">
                                            <t t-out="(object.get_base_url() or '').rstrip('/') + '/web/login?login=%s' % (object.login or object.email or '')"/>
                                        </a>
                                    </p>
                                    <p style="margin:18px 0 0 0;">Trân trọng,<br/>Ban quản trị LMS</p>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>
        </field>
    </record>

    <record id="email_template_student_welcome" model="mail.template">
        <field name="name">LMS - Welcome Student (VI)</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="subject">[LMS] Chúc mừng bạn đã được kích hoạt tài khoản học viên</field>
        <field name="email_from">{{ (user.email_formatted or user.company_id.email_formatted or '') }}</field>
        <field name="email_to">{{ object.email or object.login }}</field>
        <field name="auto_delete" eval="False"/>
        <field name="body_html" type="html">
            <table border="0" cellpadding="0" cellspacing="0" style="width:100%;background:#f6f8fb;padding:24px 0;font-family:Arial,sans-serif;color:#1f2937;">
                <tr>
                    <td align="center">
                        <table border="0" cellpadding="0" cellspacing="0" style="width:640px;max-width:94%;background:#ffffff;border:1px solid #e5e7eb;border-radius:12px;overflow:hidden;">
                            <tr>
                                <td style="background:#0ea5e9;color:#ffffff;padding:18px 24px;font-size:18px;font-weight:700;">
                                    LMS - Thông báo kích hoạt tài khoản học viên
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:24px;font-size:14px;line-height:1.7;">
                                    <p style="margin:0 0 12px 0;">Kính chào <strong><t t-out="object.name or object.login"/></strong>,</p>
                                    <p style="margin:0 0 12px 0;">
                                        Tài khoản học viên của bạn đã được phê duyệt và kích hoạt thành công trên hệ thống LMS.
                                    </p>
                                    <p style="margin:0 0 18px 0;">
                                        Bạn có thể đăng nhập để bắt đầu học tập ngay hôm nay.
                                    </p>
                                    <p style="margin:0 0 22px 0;">
                                        <a t-att-href="(object.get_base_url() or '').rstrip('/') + '/web/login?login=%s' % (object.login or object.email or '')"
                                           style="display:inline-block;background:#0ea5e9;color:#ffffff;text-decoration:none;padding:10px 18px;border-radius:8px;font-weight:600;">
                                            Đăng nhập hệ thống
                                        </a>
                                    </p>
                                    <p style="margin:0;color:#6b7280;font-size:13px;">
                                        Nếu nút không hiển thị, vui lòng truy cập:
                                        <a t-att-href="(object.get_base_url() or '').rstrip('/') + '/web/login?login=%s' % (object.login or object.email or '')">
                                            <t t-out="(object.get_base_url() or '').rstrip('/') + '/web/login?login=%s' % (object.login or object.email or '')"/>
                                        </a>
                                    </p>
                                    <p style="margin:18px 0 0 0;">Trân trọng,<br/>Ban quản trị LMS</p>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>
        </field>
    </record>
</odoo>
