<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lms_student_tree" model="ir.ui.view">
        <field name="name">lms.student.list</field>
        <field name="model">lms.student</field>
        <field name="arch" type="xml">
            <list string="Sinh viên">
                <field name="id"/>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="username"/>
                <field name="gender"/>
                <field name="date_of_birth"/>
                <field name="address"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <record id="view_lms_student_form" model="ir.ui.view">
        <field name="name">lms.student.form</field>
        <field name="model">lms.student</field>
        <field name="arch" type="xml">
            <form string="Sinh viên">
                <header>
                    <button name="action_generate_roadmap" string="Tạo Roadmap" type="object" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_generate_roadmap" type="object" class="oe_stat_button" icon="fa-graduation-cap">
                            <field name="roadmap_ids" widget="statinfo" string="Roadmap"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="gender"/>
                            <field name="date_of_birth"/>
                            <field name="address"/>
                        </group>
                        <group>
                            <field name="username" readonly="1"/>
                            <field name="current_level"/>
                            <field name="is_active"/>
                            <field name="last_login" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Mục tiêu học tập" name="goals">
                            <group>
                                <field name="learning_goals" placeholder="Nhập mục tiêu học tập..."/>
                                <field name="desired_skills" placeholder="Nhập kỹ năng mong muốn..."/>
                            </group>
                        </page>
                        <page string="Khóa học đã đăng ký" name="courses">
                            <field name="enrolled_courses_ids" nolabel="1">
                                <list>
                                    <field name="course_id"/>
                                    <field name="enrollment_date"/>
                                    <field name="status"/>
                                    <field name="progress" widget="progressbar"/>
                                    <field name="final_score"/>
                                </list>
                            </field>
                        </page>
                        <page string="Lịch sử học tập" name="history">
                            <field name="learning_history_ids" nolabel="1">
                                <list>
                                    <field name="date"/>
                                    <field name="course_id"/>
                                    <field name="lesson_id"/>
                                    <field name="study_duration"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                        <!-- <page string="Thống kê" name="statistics">
                            <group>
                                <group string="Tổng quan">
                                    <field name="total_courses"/>
                                    <field name="completed_courses"/>
                                    <field name="learning_progress" widget="progressbar"/>
                                    <field name="learning_status"/>
                                    <field name="average_score"/>
                                    <field name="total_study_time"/>
                                </group>
                            </group>
                        </page> -->
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_lms_student_kanban" model="ir.ui.view">
        <field name="name">lms.student.kanban</field>
        <field name="model">lms.student</field>
        <field name="arch" type="xml">
            <kanban default_group_by="current_level" class="o_kanban_dashboard">
                <field name="name"/>
                <field name="image_1920"/>
                <field name="current_level"/>
                <field name="total_courses"/>
                <field name="completed_courses"/>
                <field name="average_score"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_image">
                                    <img t-att-src="kanban_image('lms.student', 'image_1920', record.id.raw_value)" alt="Avatar"/>
                                </div>
                                <div class="oe_kanban_details">
                                    <strong><field name="name"/></strong>
                                    <div><field name="email"/></div>
                                    <div>Trình độ: <field name="current_level"/></div>
                                    <div>Khóa học: <field name="completed_courses"/>/<field name="total_courses"/></div>
                                    <div>Điểm TB: <field name="average_score"/></div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_lms_student" model="ir.actions.act_window">
        <field name="name">Sinh viên</field>
        <field name="res_model">lms.student</field>
        <field name="view_mode">list,kanban,form</field>
    </record>
</odoo>
