<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lms_student_search" model="ir.ui.view">
        <field name="name">lms.student.search</field>
        <field name="model">lms.student</field>
        <field name="arch" type="xml">
            <search string="Tìm kiếm học viên">
                <field name="name"/>
                <field name="email"/>
                <separator/>
                <filter string="Chờ duyệt" name="status_pending" domain="[('current_course_registration_status', '=', 'pending')]" invisible="not context.get('from_course_students')"/>
                <filter string="Đã duyệt" name="status_approved" domain="[('current_course_registration_status', '=', 'approved')]" invisible="not context.get('from_course_students')"/>
                <filter string="Từ chối" name="status_rejected" domain="[('current_course_registration_status', '=', 'rejected')]" invisible="not context.get('from_course_students')"/>
                <filter string="Đang học" name="status_learning" domain="[('current_course_registration_status', '=', 'learning')]" invisible="not context.get('from_course_students')"/>
                <filter string="Hoàn thành" name="status_completed" domain="[('current_course_registration_status', '=', 'completed')]" invisible="not context.get('from_course_students')"/>
                <filter string="Đã hủy" name="status_cancelled" domain="[('current_course_registration_status', '=', 'cancelled')]" invisible="not context.get('from_course_students')"/>
            </search>
        </field>
    </record>

    <record id="view_lms_student_tree" model="ir.ui.view">
        <field name="name">lms.student.list</field>
        <field name="model">lms.student</field>
        <field name="arch" type="xml">
            <list string="Học viên">
                <field name="id"/>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="username"/>
                <field name="gender"/>
                <field name="date_of_birth"/>
                <field name="address"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <record id="view_lms_student_tree_by_course" model="ir.ui.view">
        <field name="name">lms.student.list.by.course</field>
        <field name="model">lms.student</field>
        <field name="arch" type="xml">
            <list string="Học viên của khóa học">
                <field name="id"/>
                <field name="name"/>
                <field name="current_course_registration_status" string="Trạng thái đăng ký"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="username"/>
                <field name="gender"/>
                <field name="date_of_birth"/>
                <field name="address"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <record id="view_lms_student_form" model="ir.ui.view">
        <field name="name">lms.student.form</field>
        <field name="model">lms.student</field>
        <field name="arch" type="xml">
            <form string="Học viên">
                <header>
                    <button
                        name="action_generate_roadmap"
                        string="Tạo Roadmap"
                        type="object"
                        class="btn-primary"
                        invisible="is_instructor_restricted"
                    />
                </header>
                <sheet>
                    <field name="is_instructor_restricted" invisible="1"/>
                    <div class="oe_button_box" name="button_box">
                        <button
                            name="action_generate_roadmap"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-graduation-cap"
                            invisible="is_instructor_restricted"
                        >
                            <field name="roadmap_ids" widget="statinfo" string="Roadmap"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name" readonly="is_instructor_restricted"/>
                            <field name="email" readonly="is_instructor_restricted"/>
                            <field name="phone" readonly="is_instructor_restricted"/>
                            <field name="gender" readonly="is_instructor_restricted"/>
                            <field name="date_of_birth" readonly="is_instructor_restricted"/>
                            <field name="address" readonly="is_instructor_restricted"/>
                        </group>
                        <group>
                            <field name="username" readonly="1"/>
                            <field name="current_level" readonly="is_instructor_restricted"/>
                            <field name="is_active" readonly="is_instructor_restricted"/>
                            <field name="last_login" readonly="1"/>
                            <field
                                name="current_course_registration_status"
                                string="Trạng thái đăng ký"
                                invisible="not context.get('from_course_students')"
                                readonly="not context.get('from_course_students')"
                            />
                        </group>
                    </group>
                    <notebook>
                        <page string="Mục tiêu học tập" name="goals">
                            <group>
                                <field name="learning_goals" placeholder="Nhập mục tiêu học tập..." readonly="is_instructor_restricted"/>
                                <field name="desired_skills" placeholder="Nhập kỹ năng mong muốn..." readonly="is_instructor_restricted"/>
                            </group>
                        </page>
                        <page string="Khóa học đã đăng ký" name="courses" invisible="is_instructor_restricted">
                            <field name="enrolled_courses_ids" nolabel="1">
                                <list>
                                    <field name="course_id"/>
                                    <field name="enrollment_date"/>
                                    <field name="status"/>
                                    <field name="progress" widget="progressbar"/>
                                    <field name="final_score"/>
                                </list>
                            </field>
                        </page>
                        <page string="Lịch sử học tập" name="history" invisible="is_instructor_restricted">
                            <field name="learning_history_ids" nolabel="1">
                                <list>
                                    <field name="date"/>
                                    <field name="course_id"/>
                                    <field name="lesson_id"/>
                                    <field name="study_duration"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                        <!-- <page string="Thống kê" name="statistics">
                            <group>
                                <group string="Tổng quan">
                                    <field name="total_courses"/>
                                    <field name="completed_courses"/>
                                    <field name="learning_progress" widget="progressbar"/>
                                    <field name="learning_status"/>
                                    <field name="average_score"/>
                                    <field name="total_study_time"/>
                                </group>
                            </group>
                        </page> -->
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_lms_student_kanban" model="ir.ui.view">
        <field name="name">lms.student.kanban</field>
        <field name="model">lms.student</field>
        <field name="arch" type="xml">
            <kanban default_group_by="current_level" class="o_kanban_dashboard">
                <field name="name"/>
                <field name="image_1920"/>
                <field name="current_level"/>
                <field name="total_courses"/>
                <field name="completed_courses"/>
                <field name="average_score"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_image">
                                    <img t-att-src="kanban_image('lms.student', 'image_1920', record.id.raw_value)" alt="Avatar"/>
                                </div>
                                <div class="oe_kanban_details">
                                    <strong><field name="name"/></strong>
                                    <div><field name="email"/></div>
                                    <div>Trình độ: <field name="current_level"/></div>
                                    <div>Khóa học: <field name="completed_courses"/>/<field name="total_courses"/></div>
                                    <div>Điểm TB: <field name="average_score"/></div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_lms_student" model="ir.actions.act_window">
        <field name="name">Học viên</field>
        <field name="res_model">lms.student</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_lms_student_search"/>
    </record>

    <record id="action_lms_student_by_course" model="ir.actions.act_window">
        <field name="name">Học viên của khóa học</field>
        <field name="res_model">lms.student</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="view_id" ref="view_lms_student_tree_by_course"/>
        <field name="search_view_id" ref="view_lms_student_search"/>
        <field name="domain">[('enrolled_courses_ids.course_id', '=', (context.get('course_id') or context.get('active_id')))]</field>
    </record>

    <record id="action_lms_student_set_status_pending" model="ir.actions.server">
        <field name="name">Đặt trạng thái: Chờ duyệt</field>
        <field name="model_id" ref="model_lms_student"/>
        <field name="binding_model_id" ref="model_lms_student"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_set_course_status_pending()</field>
    </record>

    <record id="action_lms_student_set_status_approved" model="ir.actions.server">
        <field name="name">Đặt trạng thái: Đã duyệt</field>
        <field name="model_id" ref="model_lms_student"/>
        <field name="binding_model_id" ref="model_lms_student"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_set_course_status_approved()</field>
    </record>

    <record id="action_lms_student_set_status_rejected" model="ir.actions.server">
        <field name="name">Đặt trạng thái: Từ chối</field>
        <field name="model_id" ref="model_lms_student"/>
        <field name="binding_model_id" ref="model_lms_student"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_set_course_status_rejected()</field>
    </record>

    <record id="action_lms_student_set_status_learning" model="ir.actions.server">
        <field name="name">Đặt trạng thái: Đang học</field>
        <field name="model_id" ref="model_lms_student"/>
        <field name="binding_model_id" ref="model_lms_student"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_set_course_status_learning()</field>
    </record>

    <record id="action_lms_student_set_status_completed" model="ir.actions.server">
        <field name="name">Đặt trạng thái: Hoàn thành</field>
        <field name="model_id" ref="model_lms_student"/>
        <field name="binding_model_id" ref="model_lms_student"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_set_course_status_completed()</field>
    </record>

    <record id="action_lms_student_set_status_cancelled" model="ir.actions.server">
        <field name="name">Đặt trạng thái: Đã hủy</field>
        <field name="model_id" ref="model_lms_student"/>
        <field name="binding_model_id" ref="model_lms_student"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_set_course_status_cancelled()</field>
    </record>
</odoo>
